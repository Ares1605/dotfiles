{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "bash": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "search": "allow",
        "rg": "allow",
        "read": "allow",
        "read_file": "allow",
        "task": {
            "explore": "allow"
        }
    },
    "agent": {
        "investigator": {
            "mode": "primary",
            "prompt": "{file:./prompts/investigator.txt}",
            "tools": {
                "edit": true,
                "bash": true
            }
        },
        "ask": {
            "mode": "primary",
            "prompt": "Your job is to answer any questions the user has in a concise and useful manner. Be informational, and format your message cleanly to be easily readable and to the point.",
            "tools": {
                "*": false
            }
        }
    },
    "plugin": ["@mohak34/opencode-notifier@latest"]
}
